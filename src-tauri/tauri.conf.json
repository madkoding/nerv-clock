{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "NERV Clock",
	"version": "1.0.6",
	"identifier": "com.nerv.clock",
	"build": {
		"frontendDist": "../ui"
	},
	"app": {
		"withGlobalTauri": true,
		"windows": [
			{
				"title": "NERV Chronometer",
				"width": 400,
				"height": 120,
				"minWidth": 200,
				"minHeight": 60,
				"resizable": true,
				"transparent": true,
				"decorations": false,
				"alwaysOnTop": true,
				"skipTaskbar": false,
				"center": true
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}