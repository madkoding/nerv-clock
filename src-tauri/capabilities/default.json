{
	"$schema": "https://schema.tauri.app/config/2/capabilities",
	"identifier": "default",
	"description": "Default capabilities for NERV Clock",
	"windows": [
		"main"
	],
	"permissions": [
		"core:default",
		"core:window:default",
		"core:window:allow-close",
		"core:window:allow-start-dragging",
		"core:window:allow-set-always-on-top"
	]
}