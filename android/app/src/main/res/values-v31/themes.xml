<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.NervClock" parent="android:Theme.DeviceDefault.NoActionBar">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>
    
    <!-- Widget theme for Android 12+ - no rounded corners -->
    <style name="Theme.NervClock.Widget" parent="android:Theme.DeviceDefault">
        <item name="android:windowBackground">@android:color/transparent</item>
    </style>
    
    <!-- Disable system enforced rounded corners on widgets -->
    <dimen name="system_app_widget_background_radius">0dp</dimen>
    <dimen name="system_app_widget_inner_radius">0dp</dimen>
</resources>
