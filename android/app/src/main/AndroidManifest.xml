<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.nerv.clock"
    android:versionCode="220"
    android:versionName="2.2.0">
    
    <uses-sdk
        android:minSdkVersion="31"
        android:targetSdkVersion="36" />
    
    <!-- Permissions for boot and wake -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- Required for Android 12+ to schedule exact alarms -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <!-- Required for Android 13+ to use exact alarms -->
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <!-- Vibration permission -->
    <uses-permission android:name="android.permission.VIBRATE" />
    <!-- Notification permission for Android 13+ -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Foreground service permission for Android 9+ -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Foreground service type for Android 14+ -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <!-- Special use foreground service for Android 16+ -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <!-- Usage stats for launcher detection (optional but recommended) -->
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />
    <!-- Request ignore battery optimizations -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    
    <!-- Required for widgets in Android 12+ -->
    <uses-feature android:name="android.software.app_widgets" android:required="false" />
    
    <application
        android:allowBackup="false"
        android:label="@string/app_name"
        android:icon="@drawable/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.NervClock"
        android:hardwareAccelerated="true"
        android:enableOnBackInvokedCallback="true">

        <!-- Widget Receiver -->
        <receiver
            android:name=".NervClockWidget"
            android:label="@string/widget_name"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.nerv.clock.ACTION_UPDATE" />
                <action android:name="com.nerv.clock.ACTION_STOP" />
                <action android:name="com.nerv.clock.ACTION_SLOW" />
                <action android:name="com.nerv.clock.ACTION_NORMAL" />
                <action android:name="com.nerv.clock.ACTION_RACING" />
                <action android:name="com.nerv.clock.ACTION_WAKE_UPDATE" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_info" />
        </receiver>

        <!-- Boot Receiver to restart widget after device reboot -->
        <receiver
            android:name=".BootReceiver"
            android:enabled="true"
            android:exported="true"
            android:directBootAware="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
                <action android:name="android.intent.action.USER_UNLOCKED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
                <!-- Samsung specific -->
                <action android:name="android.intent.action.REBOOT" />
            </intent-filter>
        </receiver>

        <!-- Foreground Service to keep widget alive on aggressive OEMs (Xiaomi, etc.) -->
        <service
            android:name=".WidgetUpdateService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="specialUse"
            android:stopWithTask="false">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Widget clock animation updates" />
        </service>

    </application>
</manifest>
